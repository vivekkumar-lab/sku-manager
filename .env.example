# Copy this file to .env and fill in your values

# Flask session secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Comma-separated list of emails with admin access
ADMIN_EMAILS=your.name@mcaffeine.com

# Comma-separated allowed email domains (no @)
ALLOWED_DOMAINS=mcaffeine.com

# SMTP email config (for OTP delivery)
# Leave blank to print OTPs to console (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@mcaffeine.com
SMTP_PASS=your-app-password-here
SMTP_FROM_NAME=SKU Manager

# Optional: custom SQLite database path
# DB_PATH=/path/to/sku_manager.db
